rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check ownership
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Generic rule for user-owned resources
    match /{collection}/{docId} where collection in ['transactions', 'budgets', 'goals', 'recurringTransactions', 'cards'] {
      allow read, write: if request.auth != null && isOwner(request.resource.data.uid);
      allow create: if request.auth != null;
    }
  }
}
